{
  "moduleFileExtensions": [
    "ts",
    "tsx",
    "js",
    "jsx",
    "json",
    "node"
  ],
  "rootDir": "./../../",
  "testEnvironment": "node",
  "testRegex": "spec.ts$",
  "maxWorkers": 1,
  "forceExit": true,
  "testTimeout": 60000,
  "globals": {
    "NODE_ENV": "test"
  },
  "setupFiles": ["<rootDir>/test/config/jest-setup.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest",
    "^.+\\.(ts|tsx|js|jsx)$": "babel-jest"
  },
  "moduleDirectories": [
    "<rootDir>/",
    "node_modules"
  ],
  "collectCoverageFrom": [
    "src/**/*.{ts,js}",
    "!src/main.ts",
    "!src/**/*.module.ts",
    "!src/**/*.spec.ts",
    "!src/**/db/**/*.ts",
    "!src/**/config/**/*.ts",
    "!src/modules/simulado/**/*.ts",
    "!src/modules/simulado/**/*.js",
    "!src/modules/vcnafacul-form/**/*.ts",
    "!src/modules/audit-log/**/*.ts",
    "!src/utils/decorator/**/*.ts",
    "!src/**/*.dto.output.ts",
    "!src/**/*.dto.input.ts",
    "!src/**/*.entity.ts",
    "!src/**/interfaces/**/*.ts",
    "!src/**/*.enum.ts",
    "!src/**/enum/**/*.ts",
    "!src/**/enums/**/*.ts",
    "!src/**/dto/**/*.ts",
    "!src/**/dtos/**/*.ts",
    "!src/**/types/**/*.ts",
    "!src/logger/**/*.ts",
    "!src/exceptions/**/*.ts",
    "!src/shared/modules/base/entity.base.ts",
    "!src/shared/modules/env/env.ts",
    "!src/shared/services/blob/blob-service.ts",
    "!src/shared/strategy/**/*.ts",
    "!src/**/validator/**/*.ts",
    "!src/modules/geo/**/*.ts",
    "!src/modules/news/**/*.ts",
    "!src/modules/prepCourse/attendance/**/*.ts",
    "!src/modules/prepCourse/collaborator/**/*.ts",
    "!src/modules/prepCourse/partnerPrepCourse/utils/**/*.ts",
    "!src/modules/prepCourse/studentCourse/utils/**/*.ts",
    "!src/shared/modules/linked/**/*.ts",
    "!src/shared/modules/cache/cache-driver-enum.ts",
    "!src/shared/services/email/**/*.ts",
    "!src/shared/services/blob/s3-service.ts",
    "!src/shared/services/webhooks/**/*.ts",
    "!src/**/log-partner/**/*.ts",
    "!src/**/log-student/**/*.ts",
    "!src/**/legal-guardian/**/*.ts",
    "!src/**/documents/**/*.ts"
  ],
  "coverageDirectory": "./coverage",
  "coverageThreshold": {
    "global": {
      "lines": 70
    },
    "src/modules/frontend-errors/frontend-errors.service.ts": {
      "lines": 70,
      "functions": 70,
      "branches": 70
    }
  },
  "coverageReporters": [
    "text",
    "lcov",
    "text-summary"
  ]
}